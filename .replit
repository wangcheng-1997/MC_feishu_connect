# Replit configuration file

language = "javascript"

run = "npm start"

build = "npm run build"

entrypoint = "packages/backend/index.js"

modules = ["nodejs-20", "web", "nix"]

[nix]
channel = "stable-25_05"

[deployment]
build = ["npm", "run", "build"]
run = ["npm", "start"]
deploymentTarget = "gce"

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run deploy"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
